# Example environment configuration for Sentence Gymnasium.
# - DATABASE_URL is only used by the Prisma CLI (migrate diff). At runtime the
#   app talks to Cloudflare D1 via the `DB` binding, not this URL.
# - All secrets (AI_API_KEY, AUTH_SECRET, ...) are provided to Cloudflare Workers
#   via `wrangler secret put <NAME>` in production, and via `.dev.vars` locally.
#   They are NOT read from process.env at runtime.

# Prisma CLI
DATABASE_URL="file:./prisma/dev.db"

# Local dev secrets — copy into .dev.vars (do NOT commit real values)
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NUXT_SECRET=
