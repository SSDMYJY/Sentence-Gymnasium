{
  "name": "sentence-gym",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "db:generate": "prisma generate",
    "db:migrate:generate": "prisma migrate diff --from-empty --to-schema-datamodel ./prisma/schema.prisma --script --output ./migrations/0001_init.sql",
    "db:apply:local": "wrangler d1 migrations apply sentence_gym --local",
    "db:apply:remote": "wrangler d1 migrations apply sentence_gym --remote",
    "deploy": "nuxt build && wrangler deploy"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@pinia/nuxt": "^0.5.5",
    "@prisma/adapter-d1": "^6.16.0",
    "@prisma/client": "^6.16.0",
    "@sidebase/nuxt-auth": "^1.3.0",
    "bcryptjs": "^2.4.3",
    "nuxt": "^3.14.0",
    "openai": "^4.77.0",
    "pinia": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@types/bcryptjs": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "nitro-cloudflare-dev": "^0.2.0",
    "postcss": "^8.4.49",
    "prisma": "^6.16.0",
    "tailwindcss": "^3.4.17",
    "wrangler": "^3.95.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  }
}
