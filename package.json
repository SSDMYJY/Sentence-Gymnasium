{
  "name": "sentence-gym",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "prisma generate && nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "db:generate": "prisma generate",
    "db:migrate:generate": "prisma migrate diff --from-empty --to-schema-datamodel ./prisma/schema.prisma --script --output ./migrations/0001_init.sql",
    "db:apply:local": "wrangler d1 migrations apply sentence_gym --local",
    "db:apply:remote": "wrangler d1 migrations apply sentence_gym --remote",
    "deploy": "nuxt build && wrangler deploy"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.5.5",
    "@prisma/adapter-d1": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "jose": "^6.2.3",
    "nuxt": "^4.4.8",
    "openai": "^4.104.0",
    "pinia": "^2.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@iconify-json/lucide": "^1.2.116",
    "@types/bcryptjs": "^2.4.6",
    "nitro-cloudflare-dev": "^0.2.2",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.6",
    "wrangler": "^4.107.0"
  }
}
